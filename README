│   │   └── table_columns.sql
│   │
│   └── analytics/
│       ├── players/
│       ├── maps/
│       ├── matches/
│       └── infrastructure/
│
├── scripts/
│
├── .env
├── .gitignore
├── README.md
└── LICENSE
```

